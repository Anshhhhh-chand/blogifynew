<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
    <title>Agent Runs — Blogify</title>
    <style>
      .status-badge { font-size: 0.75rem; padding: 0.3em 0.7em; border-radius: 999px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
      .status-pending { background: rgba(99,102,241,0.15); color: #818cf8; border: 1px solid rgba(99,102,241,0.3); }
      .status-running { background: rgba(251,191,36,0.15); color: #fbbf24; border: 1px solid rgba(251,191,36,0.3); animation: pulse 2s infinite; }
      .status-awaiting_approval { background: rgba(245,158,11,0.2); color: #f59e0b; border: 1px solid rgba(245,158,11,0.4); }
      .status-completed { background: rgba(34,197,94,0.15); color: #4ade80; border: 1px solid rgba(34,197,94,0.3); }
      .status-failed { background: rgba(239,68,68,0.15); color: #f87171; border: 1px solid rgba(239,68,68,0.3); }
      .status-rejected { background: rgba(107,114,128,0.15); color: #9ca3af; border: 1px solid rgba(107,114,128,0.3); }
      .status-approved { background: rgba(16,185,129,0.15); color: #34d399; border: 1px solid rgba(16,185,129,0.3); }
      @keyframes pulse { 0%,100% { opacity:1 } 50% { opacity:0.6 } }
      .run-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 1.25rem 1.5rem; transition: all 0.2s; cursor: pointer; text-decoration: none; color: inherit; display: block; margin-bottom: 0.75rem; }
      .run-card:hover { background: rgba(255,255,255,0.06); border-color: rgba(99,102,241,0.4); transform: translateY(-1px); color: inherit; text-decoration: none; }
      .run-topic { font-weight: 600; font-size: 1rem; margin-bottom: 0.25rem; }
      .run-meta { font-size: 0.8rem; color: #94a3b8; }
      .trigger-card { background: linear-gradient(135deg, rgba(99,102,241,0.1), rgba(168,85,247,0.1)); border: 1px solid rgba(99,102,241,0.3); border-radius: 16px; padding: 2rem; margin-bottom: 2rem; }
      .pending-alert { background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.3); border-radius: 10px; padding: 1rem 1.25rem; margin-bottom: 1.5rem; }
    </style>
  </head>
  <body>
    <%- include('partials/nav') %>

    <div class="container mt-4" style="max-width: 860px;">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h1 style="font-size: 1.8rem; font-weight: 700;" class="gradient-text mb-1">🤖 Agent Runs</h1>
          <p class="text-muted mb-0">Your AI content pipeline executions</p>
        </div>
        <a href="/agent-runs/approvals" class="btn btn-warning btn-sm position-relative">
          Approvals
          <% if (pendingCount > 0) { %>
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.65rem;">
              <%= pendingCount %>
            </span>
          <% } %>
        </a>
      </div>

      <% if (pendingCount > 0) { %>
        <div class="pending-alert d-flex justify-content-between align-items-center">
          <div>
            <strong>⏳ <%= pendingCount %> draft<%= pendingCount > 1 ? 's' : '' %> awaiting your approval</strong>
            <div class="text-muted" style="font-size:0.85rem;">Review and approve before they're published.</div>
          </div>
          <a href="/agent-runs/approvals" class="btn btn-sm btn-warning">Review Now</a>
        </div>
      <% } %>

      <div class="trigger-card">
        <h5 class="mb-3" style="font-weight: 600;">✨ Start a New AI Pipeline Run</h5>
        <p class="text-muted mb-3" style="font-size:0.9rem;">
          The AI will <strong>plan</strong>, <strong>research</strong>, <strong>write</strong>, and <strong>self-critique</strong> a full blog post — then wait for your approval before publishing.
        </p>
        <form id="triggerForm">
          <div class="d-flex gap-2">
            <input type="text" id="topicInput" class="form-control" placeholder="Enter a topic (e.g. 'The future of AI in healthcare')" required minlength="3" maxlength="200">
            <button type="submit" class="btn btn-primary px-4" id="triggerBtn" style="white-space:nowrap;">
              <span id="triggerBtnText">Run Pipeline</span>
              <span id="triggerBtnSpinner" class="spinner-border spinner-border-sm ms-1 d-none" role="status"></span>
            </button>
          </div>
        </form>
        <div id="triggerResult" class="mt-3 d-none"></div>
      </div>

      <% if (runs.length === 0) { %>
        <div class="text-center py-5">
          <div style="font-size:3rem;">🚀</div>
          <h4 class="mt-3">No runs yet</h4>
          <p class="text-muted">Kick off your first AI pipeline run using the form above.</p>
        </div>
      <% } else { %>
        <h6 class="text-muted mb-3" style="font-size:0.8rem; text-transform:uppercase; letter-spacing:0.1em;">Recent Runs</h6>
        <% runs.forEach(function(run) { %>
          <a href="/agent-runs/<%= run._id %>" class="run-card">
            <div class="d-flex justify-content-between align-items-start">
              <div class="run-topic"><%= run.plan && run.plan.title ? run.plan.title : run.topic %></div>
              <span class="status-badge status-<%= run.status %>"><%= run.status.replace('_', ' ') %></span>
            </div>
            <div class="run-meta mt-1 d-flex gap-3">
              <span>Topic: <%= run.topic %></span>
              <% if (run.writerRetries > 0) { %><span>🔄 <%= run.writerRetries %> retries</span><% } %>
              <span><%= new Date(run.createdAt).toLocaleString() %></span>
            </div>
          </a>
        <% }) %>
      <% } %>
    </div>

    <%- include('./partials/footer') %>
    <%- include('./partials/scripts') %>
    <script>
      const form = document.getElementById('triggerForm');
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const topic = document.getElementById('topicInput').value.trim();
        const btn = document.getElementById('triggerBtn');
        const btnText = document.getElementById('triggerBtnText');
        const spinner = document.getElementById('triggerBtnSpinner');
        const result = document.getElementById('triggerResult');

        btn.disabled = true;
        btnText.textContent = 'Queuing...';
        spinner.classList.remove('d-none');

        try {
          const res = await fetch('/agent-runs', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ topic }),
          });
          const data = await res.json();
          if (data.success) {
            result.className = 'mt-3 alert alert-success';
            result.innerHTML = '\u2705 Pipeline queued! <a href="' + data.redirectUrl + '" class="alert-link">View trace \u2192</a>';
            setTimeout(function() { window.location.href = data.redirectUrl; }, 1500);
          } else {
            result.className = 'mt-3 alert alert-danger';
            result.textContent = data.error || 'Failed to queue pipeline.';
          }
        } catch (err) {
          result.className = 'mt-3 alert alert-danger';
          result.textContent = 'Network error. Please try again.';
        } finally {
          btn.disabled = false;
          btnText.textContent = 'Run Pipeline';
          spinner.classList.add('d-none');
          result.classList.remove('d-none');
        }
      });
    </script>
  </body>
</html>
